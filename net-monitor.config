# =============================================================================
# net-monitor.conf — Configuration for net-monitor.sh
# =============================================================================
 
# Network interface to scan
INTERFACE="ens0"
 
# Subnet to scan (leave empty for arp-scan auto-detect)
SUBNET="192.168.1.0/24"
 
# Discord webhook URL (or any other service accepting JSON POST)
WEBHOOK_URL="https://<your_discord_webhook_url>"
 
# Known hosts file (format: MAC|IP|description — one per line)
KNOWN_HOSTS_FILE="/root/blasch/known_hosts.conf"
 
# Already reported unknown hosts (to avoid alert spam)
SEEN_UNKNOWN_FILE="/root/blasch/seen_unknown.dat"
 
# Re-alert interval for the same unknown host (in hours)
REALERT_HOURS=1
 
# Log prefix
LOG_PREFIX="[net-monitor]"
 
